{
  "name": "@yigitahmetsahin/captcha-solver",
  "version": "1.2.0",
  "description": "AI-powered captcha solver using image preprocessing and multi-provider vision models (Vercel AI SDK)",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "scripts": {
    "build": "tsup",
    "solve": "tsx run.ts",
    "benchmark": "tsx run.ts --benchmark 20",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "format": "prettier --write .",
    "lint": "npm run format && eslint src --fix && tsc --noEmit -p tsconfig.check.json",
    "lint:check": "prettier --check . && eslint src && tsc --noEmit -p tsconfig.check.json",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "captcha",
    "solver",
    "ocr",
    "ai-sdk",
    "openai",
    "anthropic",
    "google",
    "vision",
    "image-processing",
    "typescript"
  ],
  "author": "yigitahmetsahin",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yigitahmetsahin/captcha-solver.git"
  },
  "bugs": {
    "url": "https://github.com/yigitahmetsahin/captcha-solver/issues"
  },
  "homepage": "https://github.com/yigitahmetsahin/captcha-solver#readme",
  "dependencies": {
    "ai": "^6.0.146",
    "dotenv": "^16.4.7",
    "sharp": "^0.33.5"
  },
  "devDependencies": {
    "@ai-sdk/openai": "^3.0.50",
    "@eslint/js": "^9.39.2",
    "@types/node": "^22.10.0",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "tsup": "^8.5.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.53.1",
    "vitest": "^4.0.17"
  },
  "peerDependencies": {
    "@ai-sdk/openai": ">=1.0.0",
    "@ai-sdk/anthropic": ">=1.0.0",
    "@ai-sdk/google": ">=1.0.0"
  },
  "peerDependenciesMeta": {
    "@ai-sdk/openai": {
      "optional": true
    },
    "@ai-sdk/anthropic": {
      "optional": true
    },
    "@ai-sdk/google": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=24"
  },
  "publishConfig": {
    "access": "public"
  }
}
